@startuml

left to right direction
skinparam packageStyle rectangle
skinparam shadowing false
skinparam usecase {
  BackgroundColor #F5F5F5
  BorderColor #444444
}

actor User

rectangle "Library System" {

    usecase "View Book List" as UC1
    usecase "View Book Details" as UC2
    usecase "Search Books" as UC3

    usecase "Compare REST API\nvs GraphQL API" as UC4

    usecase "View REST API\nResponse" as UC5
    usecase "View GraphQL API\nResponse" as UC6

}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

UC4 .> UC5 : <<include>>
UC4 .> UC6 : <<include>>

@enduml